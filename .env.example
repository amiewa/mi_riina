# Misskey
MISSKEY_INSTANCE_URL=https://your-instance.example.com
MISSKEY_API_TOKEN=your_token_here

# AI (使う方だけ設定する)
GEMINI_API_KEY=your_gemini_key_here

# Ollama を使う場合
OLLAMA_BASE_URL=https://your-ollama-server.example.com
# Ollama Cloud (ollama.com) を使う場合のみ設定する
OLLAMA_API_KEY=your_ollama_api_key_here

# OpenRouter を使う場合
OPENROUTER_API_KEY=your_openrouter_key_here

# ログレベル (DEBUG / INFO / WARNING / ERROR)
# ログレベルの設定はここのみ（config.yaml には含めない）
LOG_LEVEL=INFO

# タイムゾーン（コンテナのシステムタイムゾーン）
# ログのタイムスタンプやシステムコマンドに影響する
# アプリケーションロジックは zoneinfo で JST を明示的に使用するため、この設定は必須ではない
TZ=Asia/Tokyo
