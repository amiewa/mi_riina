# tl_word / static モード共通で使用
# ai モードではこのファイルは使わず、AIが全て生成する

# 質問文リスト（投稿時にランダム選択）
questions:
  - "何食べたい？"
  - "今の気分に近いのは？"
  - "週末どうしてる？"
  - "今夜のご飯、どれにする？"
  - "今日の自分に一番近いのは？"
  - "今すぐ飛び込みたいのは？"

# 接頭辞リスト（各選択肢にランダムで付与）
prefixes:
  - "爆発する"
  - "宇宙から来た"
  - "限界突破の"
  - "なぜか甘い"
  - "深夜2時の"
  - "幻の"
  - "謎に高級な"
  - "眠れない夜の"

# staticモード用アイテム（4択分がランダム選択される）
items:
  - "ステーキ"
  - "ラーメン"
  - "カレー"
  - "抹茶パフェ"
  - "シナモンロール"
  - "プリン"
  - "たこ焼き"
  - "チーズバーガー"
  - "天ぷら"
  - "鍋"
  - "サーモン丼"
  - "温泉卵のせごはん"
  - "ホットサンド"
