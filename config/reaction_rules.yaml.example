# キーワードにマッチしたTLノートに対しリアクションを送信する
# keywords: 部分一致で判定（複数指定可）
# reactions: マッチ時にランダムで1つ選択して送信
rules:
  - keywords:
      - "おはよう"
      - "おはよ"
    reactions:
      - "🌄"
      - "🌞"
      - "🌅"
  - keywords:
      - "おやすみ"
      - "おやすみなさい"
    reactions:
      - "🌙"
      - "💤"
  - keywords:
      - "かわいい"
      - "可愛い"
    reactions:
      - "❤️"
      - "🥰"
  # 以降同様に追加可能
